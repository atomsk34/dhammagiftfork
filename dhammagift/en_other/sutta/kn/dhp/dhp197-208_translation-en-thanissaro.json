{
  "dhp197:0.1": "",
  "dhp197:0.2": "",
  "dhp197:0.3": "",
  "dhp197:0.4": "",
  "dhp197:1": "How very happily we live,",
  "dhp197:2": "free from hostility among those who are hostile.",
  "dhp197:3": "Among hostile people,",
  "dhp197:4": "free from hostility we dwell.",
  "dhp198:1": "How very happily we live,",
  "dhp198:2": "free from misery among those who are miserable.",
  "dhp198:3": "Among miserable people,",
  "dhp198:4": "free from misery we dwell.",
  "dhp199:1": "How very happily we live,",
  "dhp199:2": "free from busyness among those who are busy.",
  "dhp199:3": "Among busy people,",
  "dhp199:4": "free from busyness we dwell.",
  "dhp200:0": "",
  "dhp200:1": "How very happily we live,",
  "dhp200:2": "we who have nothing.",
  "dhp200:3": "We will feed on rapture",
  "dhp200:4": "like the Radiant gods.",
  "dhp201:0": "",
  "dhp201:1": "Winning gives birth to hostility.",
  "dhp201:2": "Losing, one lies down in pain.",
  "dhp201:3": "The calmed lie down with ease,",
  "dhp201:4": "having set winning & losing aside.",
  "dhp202:0": "",
  "dhp202:1": "There’s no fire like passion,",
  "dhp202:2": "no loss like anger,",
  "dhp202:3": "no pain like the aggregates,",
  "dhp202:4": "no ease other than peace.",
  "dhp203:0": "",
  "dhp203:1": "Hunger:\nthe foremost illness.",
  "dhp203:2": "Fabrications:\nthe foremost pain.",
  "dhp203:3": "For one knowing this truth as it has come to be,",
  "dhp203:4": "Unbinding is the foremost ease.",
  "dhp204:0": "",
  "dhp204:1": "Freedom from illness:\nthe foremost good fortune.",
  "dhp204:2": "Contentment:\nthe foremost wealth.",
  "dhp204:3": "Trust:\nthe foremost kinship.",
  "dhp204:4": "Unbinding:\nthe foremost ease.",
  "dhp205:0": "",
  "dhp205:1": "Drinking the nourishment, the flavor,",
  "dhp205:2": "of seclusion & calm,",
  "dhp205:3": "one is freed from evil, devoid of distress,",
  "dhp205:4": "refreshed with the nourishment of rapture in the Dhamma.",
  "dhp206:0": "",
  "dhp206:1": "It’s good to see Noble Ones.",
  "dhp206:2": "Happy their company–always.",
  "dhp206:3": "Through not seeing fools",
  "dhp206:4": "constantly, constantly one would be happy.",
  "dhp207:1": "For, living with a fool,",
  "dhp207:2": "one grieves a long time.",
  "dhp207:3": "Painful is communion with fools,",
  "dhp207:4": "as with an enemy– always.",
  "dhp207:5": "Happy is communion with the enlightened,",
  "dhp207:6": "as with a gathering of kin.",
  "dhp208:1": "So:",
  "dhp208:2": "the enlightened man– discerning, learned,",
  "dhp208:3": "enduring, dutiful, noble,",
  "dhp208:4": "intelligent, a man of integrity:",
  "dhp208:5": "follow him –one of this sort– as the moon, the path of the zodiac stars.",
  "dhp208:6": ""
}