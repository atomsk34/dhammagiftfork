  "iti57:0.4": "",
  "iti57:1.1": "This was said by the Blessed One, said by the Arahant, so I have heard:",
  "iti57:2.1": "“Monks, there are these three effluents.",
  "iti57:2.2": "Which three?",
  "iti57:2.3": "The effluent of sensuality, the effluent of becoming, the effluent of ignorance.",
  "iti57:2.4": "These are the three effluents.”",
  "iti57:2.5": "",
  "iti57:2.6": "",
  "iti57:3.1": "His effluent of sensuality ended,",
  "iti57:3.2": "his ignorance faded away,",
  "iti57:3.3": "his effluent of becoming exhausted:",
  "iti57:3.4": "one totally released, acquisition-free,",
  "iti57:3.5": "bears his last body,",
  "iti57:3.6": "having conquered Māra along with his mount.",
  "iti57:4.1": "",
  "iti57:4.2": ""
}