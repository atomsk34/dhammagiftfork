  "thag1.18:1.1": "There was an heir to the One Awakened,",
  "thag1.18:1.2": "a monk in the Bhesakaḷā forest,",
  "thag1.18:1.3": "who suffused this whole earth",
  "thag1.18:1.4": "with the perception of “bones.”",
  "thag1.18:1.5": "Quickly, I’d say, he abandoned",
  "thag1.18:1.6": "sensual passion.",
  "thag1.18:1.7": ""
}