  "thag1.23:1.1": "I—having eaten honey-rice",
  "thag1.23:1.2": "in a bamboo patch",
  "thag1.23:1.3": "and rightly grasping the aggregates’",
  "thag1.23:1.4": "arising-disbanding—",
  "thag1.23:1.5": "will return to the hillside, intent",
  "thag1.23:1.6": "on seclusion.",
  "thag1.23:1.7": ""
}