  "thag12.1:0.2": "",
  "thag12.1:0.3": "",
  "thag12.1:0.4": "",
  "thag12.1:1.1": "Here master the virtue",
  "thag12.1:1.2": "that in this world is well-mastered,",
  "thag12.1:1.3": "for virtue, when cultivated,",
  "thag12.1:1.4": "brings every consummation near.",
  "thag12.1:2.1": "Wise, one should protect one’s virtue,",
  "thag12.1:2.2": "aspiring to three pleasures:",
  "thag12.1:2.3": "praise, the gaining of wealth,",
  "thag12.1:2.4": "and—after death—rejoicing in heaven.",
  "thag12.1:3.1": "The virtuous one, through restraint,",
  "thag12.1:3.2": "acquires many friends,",
  "thag12.1:3.3": "while the unvirtuous one, practicing evil,",
  "thag12.1:3.4": "from friends is estranged.",
  "thag12.1:4.1": "The unvirtuous person gains",
  "thag12.1:4.2": "disrepute & dishonor;",
  "thag12.1:4.3": "the virtuous person, always,",
  "thag12.1:4.4": "repute, honor, & praise.",
  "thag12.1:5.1": "Virtue is the beginning, the establishing,",
  "thag12.1:5.2": "the mother of what is fine,",
  "thag12.1:5.3": "the foremost of all qualities:",
  "thag12.1:5.4": "Therefore virtue should be purified.",
  "thag12.1:6.1": "Virtue is also control, restraint,",
  "thag12.1:6.2": "the delight of the mind,",
  "thag12.1:6.3": "the ford of all Buddhas:",
  "thag12.1:6.4": "Therefore virtue should be purified.",
  "thag12.1:7.1": "Virtue:\nan incomparable strength.",
  "thag12.1:7.2": "Virtue:\nthe ultimate weapon.",
  "thag12.1:7.3": "Virtue:\nthe highest adornment.",
  "thag12.1:7.4": "Virtue:\nan astounding coat of mail.",
  "thag12.1:8.1": "Virtue:\nan imposing bridge.",
  "thag12.1:8.2": "Virtue:\nan unexcelled fragrance.",
  "thag12.1:8.3": "Virtue:\nthe highest fragrant ointment",
  "thag12.1:8.4": "by which one wafts this direction & that.",
  "thag12.1:9.1": "Virtue:\nthe supreme provision.",
  "thag12.1:9.2": "Virtue:\nthe ultimate food for the journey.",
  "thag12.1:9.3": "Virtue:\nthe highest vehicle",
  "thag12.1:9.4": "by which one goes this direction & that.",
  "thag12.1:10.1": "Right here he gains blame,",
  "thag12.1:10.2": "and after death, in deprivation, he’s unhappy at heart:",
  "thag12.1:10.3": "Everywhere the fool is unhappy at heart,",
  "thag12.1:10.4": "not concentrated on virtues.",
  "thag12.1:11.1": "Right here he gains honor",
  "thag12.1:11.2": "and after death, in heaven, is happy at heart:",
  "thag12.1:11.3": "Everywhere the enlightened one is happy at heart,",
  "thag12.1:11.4": "well-concentrated on virtues.",
  "thag12.1:12.1": "Here virtue is supreme,",
  "thag12.1:12.2": "but one with discernment is the ultimate.",
  "thag12.1:12.3": "Among human beings & devas",
  "thag12.1:12.4": "one conquers through virtue & discernment.",
  "thag12.1:12.5": ""
}