  "thag2.26:1.1": "Shedding five hindrances",
  "thag2.26:1.2": "to reach rest from the yoke,",
  "thag2.26:1.3": "taking the Dhamma as mirror",
  "thag2.26:1.4": "my own knowledge & vision,",
  "thag2.26:2.1": "I reflected on this body—",
  "thag2.26:2.2": "the whole thing,",
  "thag2.26:2.3": "inside & out, my own & others’.",
  "thag2.26:2.4": "How vain & empty the body appeared!",
  "thag2.26:2.5": ""
}