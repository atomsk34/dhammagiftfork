  "thig8.1:0.3": "",
  "thig8.1:1.1": "Sīsūpacālā:\nA nun, consummate in virtue,",
  "thig8.1:1.2": "her faculties well-restrained,",
  "thig8.1:1.3": "will reach the state of peace,",
  "thig8.1:1.4": "a nourishment that never cloys.\nMāra:",
  "thig8.1:2.1": "The Devas of the Thirty-three,",
  "thig8.1:2.2": "the Hours, the Contented,",
  "thig8.1:2.3": "devas who delight in creation,",
  "thig8.1:2.4": "& devas in control:",
  "thig8.1:2.5": "Direct your mind there",
  "thig8.1:2.6": "where you lived before.\nSīsūpacālā:",
  "thig8.1:3.1": "The Devas of the Thirty-three,",
  "thig8.1:3.2": "the Hours, the Contented,",
  "thig8.1:3.3": "devas who delight in creation,",
  "thig8.1:3.4": "& devas in control:",
  "thig8.1:4.1": "Time & again, from becoming to becoming,",
  "thig8.1:4.2": "surrounded by self-identity,",
  "thig8.1:4.3": "not having gone beyond self-identity,",
  "thig8.1:4.4": "they flow to birth & death.",
  "thig8.1:5.1": "The whole world is burning.",
  "thig8.1:5.2": "The whole world is aflame.",
  "thig8.1:5.3": "The whole world is blazing.",
  "thig8.1:5.4": "The whole world is shaken.",
  "thig8.1:6.1": "The unshaken, incomparable —the Dhamma the Buddha taught to me,",
  "thig8.1:6.2": "of which people run-of-the-mill don’t partake—",
  "thig8.1:6.3": "",
  "thig8.1:6.4": "that’s where my heart truly delights.",
  "thig8.1:7.1": "Having heard his words,",
  "thig8.1:7.2": "I dwell, delighting in his bidding.",
  "thig8.1:7.3": "The three knowledges are attained;",
  "thig8.1:7.4": "the Buddha’s bidding, done.",
  "thig8.1:8.1": "Everywhere enjoyment is defeated;",
  "thig8.1:8.2": "the mass of darkness, burst.",
  "thig8.1:8.3": "So know, Evil One,",
  "thig8.1:8.4": "that you have been, End-maker, struck down.",
  "thig8.1:9.1": "",
  "thig8.1:10.1": ""
}