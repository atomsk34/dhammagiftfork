{
  "sn1.64:0.1": "Linked Discourses 1.64 ",
  "sn1.64:0.2": "Chapter Addha ",
  "sn1.64:0.3": "Sutta Fetter ",
  "sn1.64:1.1": "“With what is the world fettered? ",
  "sn1.64:1.2": "What is its exploration? ",
  "sn1.64:1.3": "With the abandoning ",
  "sn1.64:1.4": "of what is there said, ‘unbinding’?” ",
  "sn1.64:2.1": "The Buddha: “Fettered with delight is the world. ",
  "sn1.64:2.2": "Directed thought is its exploration. ",
  "sn1.64:2.3": "With the abandoning of craving ",
  "sn1.64:2.4": "is there said, ‘unbinding.’”"
}