{
  "sn25.4:0.1": "Linked Discourses 25.4 ",
  "sn25.4:0.2": "The Cakkhu Chapter ",
  "sn25.4:0.3": "Sutta Consciousness ",
  "sn25.4:1.1": "Near Sāvatthī. ",
  "sn25.4:1.2": "“Monks, eye-contact is inconstant, changeable, alterable. ",
  "sn25.4:1.3": "Ear-contact.… ",
  "sn25.4:1.4": "Nose-contact.… ",
  "sn25.4:1.5": "Tongue-contact.… ",
  "sn25.4:1.6": "Body-contact.… ",
  "sn25.4:1.7": "Intellect-contact is inconstant, changeable, alterable… ",
  "sn25.4:1.8": "“One who has conviction & belief that these phenomena are this way is called a faith-follower... ",
  "sn25.4:1.9": "headed for self-awakening.”",
  "sn25.4:1.10": "The Fourth."
}