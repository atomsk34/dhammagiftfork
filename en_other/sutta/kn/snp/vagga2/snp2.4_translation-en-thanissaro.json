{
  "snp2.4:0.1": "",
  "snp2.4:0.2": "",
  "snp2.4:1.1": "I have heard that",
  "snp2.4:1.2": "at one time the Blessed One was staying near Sāvatthī in Jeta’s Grove, Anāthapiṇḍika’s monastery.",
  "snp2.4:1.3": "Then a certain deva, in the far extreme of the night,\nher extreme radiance lighting up the entirety of Jeta’s Grove, went to the Blessed One.",
  "snp2.4:1.4": "On arrival, having bowed down to him, she stood to one side.\nAs she was standing there, she addressed him with a verse.",
  "snp2.4:2.1": "“Many devas & human beings",
  "snp2.4:2.2": "give thought to protection,",
  "snp2.4:2.3": "desiring well-being.",
  "snp2.4:2.4": "Tell, then, the highest protection.”\nThe Buddha:",
  "snp2.4:3.1": "“Not consorting with fools,",
  "snp2.4:3.2": "consorting with the wise,",
  "snp2.4:3.3": "paying homage to those worthy of homage:",
  "snp2.4:3.4": "This is the highest protection.",
  "snp2.4:4.1": "Living in a civilized land,",
  "snp2.4:4.2": "having made merit in the past,",
  "snp2.4:4.3": "directing oneself rightly:",
  "snp2.4:4.4": "This is the highest protection.",
  "snp2.4:5.1": "Broad knowledge, skill,",
  "snp2.4:5.2": "well-mastered discipline,",
  "snp2.4:5.3": "well-spoken words:",
  "snp2.4:5.4": "This is the highest protection.",
  "snp2.4:6.1": "Support for one’s mother & father,",
  "snp2.4:6.2": "assistance to one’s wife and children,",
  "snp2.4:6.3": "consistency in one’s work:",
  "snp2.4:6.4": "This is the highest protection.",
  "snp2.4:7.1": "Generosity, living in rectitude,",
  "snp2.4:7.2": "assistance to one’s relatives,",
  "snp2.4:7.3": "deeds that are blameless:",
  "snp2.4:7.4": "This is the highest protection.",
  "snp2.4:8.1": "Avoiding, abstaining from evil;",
  "snp2.4:8.2": "refraining from intoxicants,",
  "snp2.4:8.3": "being heedful of mental qualities:",
  "snp2.4:8.4": "This is the highest protection.",
  "snp2.4:9.1": "Respect, humility,",
  "snp2.4:9.2": "contentment, gratitude,",
  "snp2.4:9.3": "hearing the Dhamma on timely occasions:",
  "snp2.4:9.4": "This is the highest protection.",
  "snp2.4:10.1": "Patience, being easy to instruct,",
  "snp2.4:10.2": "seeing contemplatives,",
  "snp2.4:10.3": "discussing the Dhamma on timely occasions:",
  "snp2.4:10.4": "This is the highest protection.",
  "snp2.4:11.1": "Austerity, celibacy,",
  "snp2.4:11.2": "seeing the noble truths,",
  "snp2.4:11.3": "realizing unbinding:",
  "snp2.4:11.4": "This is the highest protection.",
  "snp2.4:12.1": "A mind that, when touched by the ways of the world,",
  "snp2.4:12.2": "is unshaken, sorrowless, dustless, at rest:",
  "snp2.4:12.3": "",
  "snp2.4:12.4": "This is the highest protection.",
  "snp2.4:13.1": "When acting in this way,",
  "snp2.4:13.2": "everywhere undefeated,",
  "snp2.4:13.3": "people go everywhere in well-being:",
  "snp2.4:13.4": "This is their highest protection.”",
  "snp2.4:13.5": ""
}