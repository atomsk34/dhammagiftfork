  "thag14.1:0.1": "",
  "thag14.1:0.2": "",
  "thag14.1:0.3": "",
  "thag14.1:0.4": "",
  "thag14.1:1.1": "Since I went forth",
  "thag14.1:1.2": "from home into homelessness,",
  "thag14.1:1.3": "I haven’t known",
  "thag14.1:1.4": "an ignoble, aversive resolve.",
  "thag14.1:2.1": "“May these beings be destroyed, be slaughtered,",
  "thag14.1:2.2": "fall into pain”—",
  "thag14.1:2.3": "I’ve not known this resolve",
  "thag14.1:2.4": "in this long, long time.",
  "thag14.1:3.1": "But I have known goodwill,",
  "thag14.1:3.2": "unlimited, fully developed,",
  "thag14.1:3.3": "nurtured step after step,",
  "thag14.1:3.4": "as taught by the One Awake:",
  "thag14.1:4.1": "to all, a friend;\nto all, a comrade;",
  "thag14.1:4.2": "for all beings, sympathetic.",
  "thag14.1:4.3": "And I develop a mind of goodwill,",
  "thag14.1:4.4": "delighting in non-malevolence —always.",
  "thag14.1:5.1": "Unvanquished, unshaken,",
  "thag14.1:5.2": "I gladden the mind.",
  "thag14.1:5.3": "I develop the sublime abiding,",
  "thag14.1:5.4": "not frequented by the lowly.",
  "thag14.1:6.1": "Attaining no-thinking,",
  "thag14.1:6.2": "the disciple of the Rightly Self-awakened One",
  "thag14.1:6.3": "is endowed with noble silence",
  "thag14.1:6.4": "straightaway.",
  "thag14.1:7.1": "As a mountain of rock",
  "thag14.1:7.2": "is unmoving, firmly established,",
  "thag14.1:7.3": "so a monk, with the ending of delusion,",
  "thag14.1:7.4": "like a mountain, doesn’t quake.",
  "thag14.1:8.1": "To a person without blemish,",
  "thag14.1:8.2": "in constant quest of what’s pure,",
  "thag14.1:8.3": "a hair-tip of evil",
  "thag14.1:8.4": "seems a storm cloud.",
  "thag14.1:9.1": "As a frontier fortress is guarded",
  "thag14.1:9.2": "within & without,",
  "thag14.1:9.3": "you should safeguard yourselves.",
  "thag14.1:9.4": "Don’t let the moment pass you by.",
  "thag14.1:10.1": "I don’t delight in death,",
  "thag14.1:10.2": "don’t delight in living.",
  "thag14.1:10.3": "I await my time",
  "thag14.1:10.4": "like a worker his wage.",
  "thag14.1:11.1": "I don’t delight in death,",
  "thag14.1:11.2": "don’t delight in living.",
  "thag14.1:11.3": "I await my time,",
  "thag14.1:11.4": "mindful, alert.",
  "thag14.1:12.1": "The Teacher has been served by me;",
  "thag14.1:12.2": "the Awakened One’s bidding, done;",
  "thag14.1:12.3": "the heavy load, laid down;",
  "thag14.1:12.4": "the guide to becoming, uprooted.",
  "thag14.1:13.1": "And the goal for which I went forth",
  "thag14.1:13.2": "from home life into homelessness",
  "thag14.1:13.3": "I’ve reached:",
  "thag14.1:13.4": "the end of all fetters.",
  "thag14.1:14.1": "Attain consummation through heedfulness:",
  "thag14.1:14.2": "That is my message.",
  "thag14.1:14.3": "So then, I’m about to unbind.",
  "thag14.1:14.4": "I’m released everywhere.",
  "thag14.1:14.5": ""
}