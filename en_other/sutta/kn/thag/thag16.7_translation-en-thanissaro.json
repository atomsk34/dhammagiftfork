{
  "thag16.7:0.1": "",
  "thag16.7:0.2": "",
  "thag16.7:0.3": "",
  "thag16.7:0.4": "",
  "thag16.7:1.1": "Whatever the fine clothes I wore",
  "thag16.7:1.2": "when astride the elephant’s neck,",
  "thag16.7:1.3": "whatever the fine rice I ate, the pure meat sauce,",
  "thag16.7:1.4": "",
  "thag16.7:2.1": "today—fortunate, persevering,",
  "thag16.7:2.2": "delighting in whatever falls into his bowl,",
  "thag16.7:2.3": "Bhaddiya, son of Godhā,",
  "thag16.7:2.4": "does jhāna without clinging.",
  "thag16.7:3.1": "Wearing cast-off cloth, persevering,",
  "thag16.7:3.2": "delighting in whatever falls into his bowl,",
  "thag16.7:3.3": "Bhaddiya, son of Godhā,",
  "thag16.7:3.4": "does jhāna without clinging.",
  "thag16.7:4.1": "Going for alms, persevering,",
  "thag16.7:4.2": "delighting in whatever falls into his bowl,",
  "thag16.7:4.3": "Bhaddiya, son of Godhā,",
  "thag16.7:4.4": "does jhāna without clinging.",
  "thag16.7:5.1": "Wearing only one triple set of robes, persevering…",
  "thag16.7:5.2": "",
  "thag16.7:5.3": "",
  "thag16.7:5.4": "",
  "thag16.7:6.1": "Bypassing no donors on his alms round, persevering…",
  "thag16.7:6.2": "",
  "thag16.7:6.3": "",
  "thag16.7:6.4": "",
  "thag16.7:7.1": "Eating only one meal a day, persevering…",
  "thag16.7:7.2": "",
  "thag16.7:7.3": "",
  "thag16.7:7.4": "",
  "thag16.7:8.1": "Eating from the bowl, persevering…",
  "thag16.7:8.2": "",
  "thag16.7:8.3": "",
  "thag16.7:8.4": "",
  "thag16.7:9.1": "Refusing food brought afterwards, persevering…",
  "thag16.7:9.2": "",
  "thag16.7:9.3": "",
  "thag16.7:9.4": "",
  "thag16.7:10.1": "Living in the wilderness, persevering…",
  "thag16.7:10.2": "",
  "thag16.7:10.3": "",
  "thag16.7:10.4": "",
  "thag16.7:11.1": "Living at the foot of a tree, persevering…",
  "thag16.7:11.2": "",
  "thag16.7:11.3": "",
  "thag16.7:11.4": "",
  "thag16.7:12.1": "Living in the open air, persevering…",
  "thag16.7:12.2": "",
  "thag16.7:12.3": "",
  "thag16.7:12.4": "",
  "thag16.7:13.1": "Living in a cemetery, persevering…",
  "thag16.7:13.2": "",
  "thag16.7:13.3": "",
  "thag16.7:13.4": "",
  "thag16.7:14.1": "Accepting whatever lodging he’s assigned, persevering,",
  "thag16.7:14.2": "",
  "thag16.7:14.3": "",
  "thag16.7:14.4": "",
  "thag16.7:15.1": "Not lying down, persevering,",
  "thag16.7:15.2": "delighting in whatever falls into his bowl,",
  "thag16.7:15.3": "Bhaddiya, son of Godhā,",
  "thag16.7:15.4": "does jhāna without clinging.",
  "thag16.7:16.1": "Modest, persevering…",
  "thag16.7:16.2": "",
  "thag16.7:16.3": "",
  "thag16.7:16.4": "",
  "thag16.7:17.1": "Content, persevering…",
  "thag16.7:17.2": "",
  "thag16.7:17.3": "",
  "thag16.7:17.4": "",
  "thag16.7:18.1": "Secluded, persevering…",
  "thag16.7:18.2": "",
  "thag16.7:18.3": "",
  "thag16.7:18.4": "",
  "thag16.7:19.1": "Unentangled, persevering…",
  "thag16.7:19.2": "",
  "thag16.7:19.3": "",
  "thag16.7:19.4": "",
  "thag16.7:20.1": "Energy aroused, persevering,",
  "thag16.7:20.2": "delighting in whatever falls into his bowl,",
  "thag16.7:20.3": "Bhaddiya, son of Godhā,",
  "thag16.7:20.4": "does jhāna without clinging.",
  "thag16.7:21.1": "Abandoning a 100-carat bowl of bronze",
  "thag16.7:21.2": "and a 100-weight bowl of gold,",
  "thag16.7:21.3": "I took instead a bowl of clay:",
  "thag16.7:21.4": "That was my second consecration.",
  "thag16.7:22.1": "In the midst of high encircling walls,",
  "thag16.7:22.2": "strong battlements & gates,",
  "thag16.7:22.3": "guarded by men with swords in hand—",
  "thag16.7:22.4": "trembling I used to live.",
  "thag16.7:23.1": "Today, fortunate, unafraid,",
  "thag16.7:23.2": "with fear & terror abandoned,",
  "thag16.7:23.3": "Bhaddiya, son of Godhā,",
  "thag16.7:23.4": "having plunged into the forest, does jhāna.",
  "thag16.7:24.1": "Standing firm in the aggregate of virtue,",
  "thag16.7:24.2": "developing mindfulness & discernment,",
  "thag16.7:24.3": "step by step I attained",
  "thag16.7:24.4": "the ending of all fetters.",
  "thag16.7:24.5": ""
}