  "thag3.15:0.4": "",
  "thag3.15:1.1": "Whoever wants to do later",
  "thag3.15:1.2": "what he should have done first,",
  "thag3.15:1.3": "falls away from the easeful state",
  "thag3.15:1.4": "& later repents.",
  "thag3.15:2.1": "One should speak as one would act,",
  "thag3.15:2.2": "& not as one wouldn’t.",
  "thag3.15:2.3": "When one speaks without acting,",
  "thag3.15:2.4": "the wise, they can tell.",
  "thag3.15:3.1": "How very easeful:\nunbinding,",
  "thag3.15:3.2": "as taught by the Rightly Self-awakened One—",
  "thag3.15:3.3": "sorrowless, dustless, secure,",
  "thag3.15:3.4": "where stress & suffering cease.",
  "thag3.15:3.5": ""
}