  "thag3.5:0.1": "",
  "thag3.5:0.2": "",
  "thag3.5:0.3": "",
  "thag3.5:0.4": "",
  "thag3.5:1.1": "It’s too cold, too hot,",
  "thag3.5:1.2": "too late in the evening—",
  "thag3.5:1.3": "people who say this, shirking their work:",
  "thag3.5:1.4": "The moment passes them by.",
  "thag3.5:2.1": "Whoever regards cold & heat",
  "thag3.5:2.2": "as no more than grass,",
  "thag3.5:2.3": "doing his manly duties,",
  "thag3.5:2.4": "won’t fall away from ease.",
  "thag3.5:3.1": "With my chest I push through wild grasses—",
  "thag3.5:3.2": "spear-grass, ribbon-grass,",
  "thag3.5:3.3": "rushes—",
  "thag3.5:3.4": "cultivating a heart bent on seclusion.",
  "thag3.5:3.5": ""
}