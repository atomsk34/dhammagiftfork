  "thag5.8:1.1": "Stricken by sharp, wind-like pains,",
  "thag5.8:1.2": "you, monk, living in the forest grove",
  "thag5.8:1.3": "—harsh, with limited range for alms—",
  "thag5.8:1.4": "what, what will you do?\nSuffusing my body",
  "thag5.8:2.1": "with abundant rapture & joy,",
  "thag5.8:2.2": "",
  "thag5.8:2.3": "& enduring what’s harsh,",
  "thag5.8:2.4": "I’ll stay in the grove.",
  "thag5.8:3.1": "Developing the establishings of mindfulness,",
  "thag5.8:3.2": "strengths, faculties,",
  "thag5.8:3.3": "the factors for awakening,",
  "thag5.8:3.4": "I’ll stay in the grove.",
  "thag5.8:4.1": "Reflecting on those who are resolute, their persistence aroused,",
  "thag5.8:4.2": "constantly firm in their effort,",
  "thag5.8:4.3": "united in concord,",
  "thag5.8:4.4": "I’ll stay in the grove.",
  "thag5.8:5.1": "Recollecting the One Self-awakened,",
  "thag5.8:5.2": "self-tamed & centered,",
  "thag5.8:5.3": "untiring both day & night,",
  "thag5.8:5.4": "I’ll stay in the grove.",
  "thag5.8:5.5": ""
}