  "thag6.10:0.1": "",
  "thag6.10:0.2": "",
  "thag6.10:0.3": "",
  "thag6.10:0.4": "",
  "thag6.10:1.1": "When I was seven",
  "thag6.10:1.2": "& newly gone forth,",
  "thag6.10:1.3": "having conquered with my power",
  "thag6.10:1.4": "the great powerful serpent,",
  "thag6.10:2.1": "I was fetching water for my preceptor",
  "thag6.10:2.2": "from the great lake, Anotatta,",
  "thag6.10:2.3": "",
  "thag6.10:2.4": "when the Teacher saw me & said:",
  "thag6.10:3.1": "“Look, Sāriputta, at that one,",
  "thag6.10:3.2": "the young boy coming there,",
  "thag6.10:3.3": "carrying a pot of water,",
  "thag6.10:3.4": "well-centered within,",
  "thag6.10:4.1": "his practices—inspiring;",
  "thag6.10:4.2": "his bearing—admirable.",
  "thag6.10:4.3": "He’s Anuruddha’s novice,",
  "thag6.10:4.4": "mature in his powers,",
  "thag6.10:5.1": "made thoroughbred by a thoroughbred,",
  "thag6.10:5.2": "good by one who is good,",
  "thag6.10:5.3": "tamed by Anuruddha,",
  "thag6.10:5.4": "trained by one whose task is done.",
  "thag6.10:6.1": "He, having reached the highest peace",
  "thag6.10:6.2": "& realized the unshakable,",
  "thag6.10:6.3": "Sumana the novice",
  "thag6.10:6.4": "wants this:\n‘Don’t let anyone know me.’”",
  "thag6.10:6.5": ""
}