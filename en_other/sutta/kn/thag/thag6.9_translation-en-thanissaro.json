  "thag6.9:0.1": "",
  "thag6.9:0.2": "",
  "thag6.9:0.3": "",
  "thag6.9:0.4": "",
  "thag6.9:1.1": "I was drunk with the intoxication",
  "thag6.9:1.2": "of my birth, wealth, & sovereignty.",
  "thag6.9:1.3": "Drunk with the intoxication of my body’s build, coloring, & form,",
  "thag6.9:1.4": "I wandered about,",
  "thag6.9:2.1": "regarding no one",
  "thag6.9:2.2": "as my equal or better.",
  "thag6.9:2.3": "Foolish, arrogant, haughty,",
  "thag6.9:2.4": "my banner held high.\nI—disrespectful, arrogant, proud— bowed down to no one,",
  "thag6.9:3.1": "not even mother, father,",
  "thag6.9:3.2": "or those commonly held in respect.",
  "thag6.9:3.3": "",
  "thag6.9:3.4": "",
  "thag6.9:4.1": "Then—seeing the ultimate leader,",
  "thag6.9:4.2": "supreme, foremost of charioteers,",
  "thag6.9:4.3": "like a blazing sun,",
  "thag6.9:4.4": "arrayed with a squadron of monks—",
  "thag6.9:5.1": "casting away pride & intoxication",
  "thag6.9:5.2": "through an awareness serene & clear,",
  "thag6.9:5.3": "I bowed down my head",
  "thag6.9:5.4": "to him, supreme among all living beings.",
  "thag6.9:6.1": "Haughtiness & contempt",
  "thag6.9:6.2": "have been abandoned —rooted out—",
  "thag6.9:6.3": "the conceit “I am” is extracted,",
  "thag6.9:6.4": "all forms of pride, destroyed.",
  "thag6.9:6.5": ""
}