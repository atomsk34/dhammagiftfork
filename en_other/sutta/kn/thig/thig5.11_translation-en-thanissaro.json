  "thig5.11:0.3": "",
  "thig5.11:1.1": "[Paṭācārā taught:] “Taking the pestle,",
  "thig5.11:1.2": "young men grind the corn.",
  "thig5.11:1.3": "Supporting their wives & children,",
  "thig5.11:1.4": "they gather up wealth.",
  "thig5.11:2.1": "Do the Awakened One’s bidding,",
  "thig5.11:2.2": "which, having done, you’ll have no regret.\nIntent on tranquility of awareness, do the Awakened One’s bidding.",
  "thig5.11:2.3": "Quickly:\nHaving washed your feet,",
  "thig5.11:2.4": "go sit to one side.”",
  "thig5.11:2.5": "",
  "thig5.11:2.6": "",
  "thig5.11:3.1": "Hearing these words,",
  "thig5.11:3.2": "Paṭācārā’s bidding,",
  "thig5.11:3.3": "they washed their feet",
  "thig5.11:3.4": "and retired to one side.",
  "thig5.11:3.5": "Intent on tranquility of awareness,",
  "thig5.11:3.6": "they did the Awakened One’s bidding.",
  "thig5.11:4.1": "In the first watch of the night,",
  "thig5.11:4.2": "they recollected their previous lives.",
  "thig5.11:4.3": "In the middle watch,",
  "thig5.11:4.4": "purified the divine eye.",
  "thig5.11:4.5": "In the last,",
  "thig5.11:4.6": "burst the mass of darkness.",
  "thig5.11:5.1": "Getting up, they bowed down to her feet.",
  "thig5.11:5.2": "“We have done your bidding.",
  "thig5.11:5.3": "Like the thirty devas honoring Indra,",
  "thig5.11:5.4": "unvanquished in battle,",
  "thig5.11:5.5": "we—",
  "thig5.11:5.6": "endowed with the three knowledges, effluent-free— will continue honoring you.”",
  "thig5.11:6.1": ""
}