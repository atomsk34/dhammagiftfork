  "thig5.4:0.1": "",
  "thig5.4:0.2": "",
  "thig5.4:0.3": "",
  "thig5.4:1.1": "“Sick, putrid, unclean:",
  "thig5.4:1.2": "look, Nandā, at this physical heap.",
  "thig5.4:1.3": "Through contemplation of the foul, develop your mind,",
  "thig5.4:1.4": "make it one, well-centered.",
  "thig5.4:2.1": "As this [your body], so that.",
  "thig5.4:2.2": "As that, so this.",
  "thig5.4:2.3": "It gives off a foul stench,",
  "thig5.4:2.4": "the delight of fools.”",
  "thig5.4:3.1": "Considering it thus,",
  "thig5.4:3.2": "untiring, both day & night,",
  "thig5.4:3.3": "I, with my own discernment",
  "thig5.4:3.4": "dissecting it, saw.",
  "thig5.4:4.1": "And as I, heedful,",
  "thig5.4:4.2": "examined it aptly,",
  "thig5.4:4.3": "this body—as it actually is—",
  "thig5.4:4.4": "was seen inside & out.",
  "thig5.4:5.1": "Then was I disenchanted with the body",
  "thig5.4:5.2": "& dispassionate within:",
  "thig5.4:5.3": "Heedful, detached,",
  "thig5.4:5.4": "calmed was I. Unbound.",
  "thig5.4:6.1": ""
}