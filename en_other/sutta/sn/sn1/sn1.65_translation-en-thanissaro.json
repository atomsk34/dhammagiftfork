{
  "sn1.65:0.1": "Linked Discourses 1.65 ",
  "sn1.65:0.2": "Chapter Addha ",
  "sn1.65:0.3": "Sutta Bondage ",
  "sn1.65:1.1": "“With what \tis the world placed in bondage? ",
  "sn1.65:1.2": "What is its exploration? ",
  "sn1.65:1.3": "With the abandoning of what ",
  "sn1.65:1.4": "are all bonds broken?” ",
  "sn1.65:2.1": "“With delight is the world placed in bondage. ",
  "sn1.65:2.2": "Directed thought is its exploration. ",
  "sn1.65:2.3": "With the abandoning of craving ",
  "sn1.65:2.4": "all bonds are broken.”"
}