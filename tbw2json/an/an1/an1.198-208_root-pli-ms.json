{
  "an1.198:0.1": "Aṅguttara Nikāya 1 ",
  "an1.198:0.2": "15. Dutiyavagga ",
  "an1.198-208:1.1": "\"Etadaggaṁ, bhikkhave, mama sāvakānaṁ bhikkhūnaṁ manomayaṁ kāyaṁ abhinimminantānaṁ yadidaṁ cūḷapanthako.\n(1)",
  "an1.198-208:1.2": "…   Cetovivaṭṭakusalānaṁ yadidaṁ cūḷapanthako.\n(2)",
  "an1.198-208:1.3": "…   Saññāvivaṭṭakusalānaṁ yadidaṁ mahāpanthako.\n(3)",
  "an1.198-208:1.4": "…   Araṇavihārīnaṁ yadidaṁ subhūti.\n(4)",
  "an1.198-208:1.5": "…   Dakkhiṇeyyānaṁ yadidaṁ subhūti.\n(5)",
  "an1.198-208:1.6": "…   Āraññakānaṁ yadidaṁ revato khadiravaniyo.\n(6)",
  "an1.198-208:1.7": "…   Jhāyīnaṁ yadidaṁ kaṅkhārevato.\n(7)",
  "an1.198-208:1.8": "…   Āraddhavīriyānaṁ yadidaṁ soṇo koḷiviso.\n(8)",
  "an1.198-208:1.9": "…   Kalyāṇavākkaraṇānaṁ yadidaṁ soṇo kuṭikaṇṇo.\n(9)",
  "an1.198-208:1.10": "…   Lābhīnaṁ yadidaṁ sīvali.\n(10)",
  "an1.198-208:1.11": "…   Saddhādhimuttānaṁ yadidaṁ vakkalī\"ti.\n(11)\nVaggo dutiyo.\nDutiyavagga"
}