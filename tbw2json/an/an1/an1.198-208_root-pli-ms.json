{
  "an1.198:0.1": "Aṅguttara Nikāya 1 ",
  "an1.198:0.2": "15. Dutiyavagga ",
  "an1.198-208:1.1": "\"Etadaggaṁ, bhikkhave, mama sāvakānaṁ bhikkhūnaṁ manomayaṁ kāyaṁ abhinimminantānaṁ yadidaṁ cūḷapanthako.",
  "an1.198-208:1.2": "…   Cetovivaṭṭakusalānaṁ yadidaṁ cūḷapanthako.",
  "an1.198-208:1.3": "…   Saññāvivaṭṭakusalānaṁ yadidaṁ mahāpanthako.",
  "an1.198-208:1.4": "…   Araṇavihārīnaṁ yadidaṁ subhūti.",
  "an1.198-208:1.5": "…   Dakkhiṇeyyānaṁ yadidaṁ subhūti.",
  "an1.198-208:1.6": "…   Āraññakānaṁ yadidaṁ revato khadiravaniyo.",
  "an1.198-208:1.7": "…   Jhāyīnaṁ yadidaṁ kaṅkhārevato.",
  "an1.198-208:1.8": "…   Āraddhavīriyānaṁ yadidaṁ soṇo koḷiviso.",
  "an1.198-208:1.9": "…   Kalyāṇavākkaraṇānaṁ yadidaṁ soṇo kuṭikaṇṇo.",
  "an1.198-208:1.10": "…   Lābhīnaṁ yadidaṁ sīvali.",
  "an1.198-208:1.11": "…   Saddhādhimuttānaṁ yadidaṁ vakkalī\"ti.\nVaggo dutiyo.\nDutiyavagga"
}