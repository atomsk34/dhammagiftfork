{
  "an1.209:0.1": "Aṅguttara Nikāya 1 ",
  "an1.209:0.2": "16. Tatiyavagga ",
  "an1.209-218:1.1": "\"Etadaggaṁ, bhikkhave, mama sāvakānaṁ bhikkhūnaṁ sikkhākāmānaṁ yadidaṁ rāhulo.\n(1)",
  "an1.209-218:1.2": "…   Saddhāpabbajitānaṁ yadidaṁ raṭṭhapālo.\n(2)",
  "an1.209-218:1.3": "…   Paṭhamaṁ salākaṁ gaṇhantānaṁ yadidaṁ kuṇḍadhāno.\n(3)",
  "an1.209-218:1.4": "…   Paṭibhānavantānaṁ yadidaṁ vaṅgīso.\n(4)",
  "an1.209-218:1.5": "…   Samantapāsādikānaṁ yadidaṁ upaseno vaṅgantaputto.\n(5)",
  "an1.209-218:1.6": "…   Senāsanapaññāpakānaṁ yadidaṁ dabbo mallaputto.\n(6)",
  "an1.209-218:1.7": "…   Devatānaṁ piyamanāpānaṁ yadidaṁ pilindavaccho.\n(7)",
  "an1.209-218:1.8": "…   Khippābhiññānaṁ yadidaṁ bāhiyo dārucīriyo.\n(8)",
  "an1.209-218:1.9": "…   Cittakathikānaṁ yadidaṁ kumārakassapo.\n(9)",
  "an1.209-218:1.10": "…   Paṭisambhidāpattānaṁ yadidaṁ mahākoṭṭhito\"ti.\n(10)\nVaggo tatiyo.\nTatiyavagga"
}