{
  "an1.209:0.1": "Aṅguttara Nikāya 1 ",
  "an1.209:0.2": "16. Tatiyavagga ",
  "an1.209-218:1.1": "\"Etadaggaṁ, bhikkhave, mama sāvakānaṁ bhikkhūnaṁ sikkhākāmānaṁ yadidaṁ rāhulo.",
  "an1.209-218:1.2": "…   Saddhāpabbajitānaṁ yadidaṁ raṭṭhapālo.",
  "an1.209-218:1.3": "…   Paṭhamaṁ salākaṁ gaṇhantānaṁ yadidaṁ kuṇḍadhāno.",
  "an1.209-218:1.4": "…   Paṭibhānavantānaṁ yadidaṁ vaṅgīso.",
  "an1.209-218:1.5": "…   Samantapāsādikānaṁ yadidaṁ upaseno vaṅgantaputto.",
  "an1.209-218:1.6": "…   Senāsanapaññāpakānaṁ yadidaṁ dabbo mallaputto.",
  "an1.209-218:1.7": "…   Devatānaṁ piyamanāpānaṁ yadidaṁ pilindavaccho.",
  "an1.209-218:1.8": "…   Khippābhiññānaṁ yadidaṁ bāhiyo dārucīriyo.",
  "an1.209-218:1.9": "…   Cittakathikānaṁ yadidaṁ kumārakassapo.",
  "an1.209-218:1.10": "…   Paṭisambhidāpattānaṁ yadidaṁ mahākoṭṭhito\"ti.\nVaggo tatiyo.\nTatiyavagga"
}