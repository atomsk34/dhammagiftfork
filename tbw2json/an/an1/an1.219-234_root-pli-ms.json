{
  "an1.219:0.1": "Aṅguttara Nikāya 1 ",
  "an1.219:0.2": "17. Catutthavagga ",
  "an1.219-234:1.1": "\"Etadaggaṁ, bhikkhave, mama sāvakānaṁ bhikkhūnaṁ bahussutānaṁ yadidaṁ ānando.\n(1)",
  "an1.219-234:1.2": "…   Satimantānaṁ yadidaṁ ānando.\n(2)",
  "an1.219-234:1.3": "…   Gatimantānaṁ yadidaṁ ānando.\n(3)",
  "an1.219-234:1.4": "…   Dhitimantānaṁ yadidaṁ ānando.\n(4)",
  "an1.219-234:1.5": "…   Upaṭṭhākānaṁ yadidaṁ ānando.\n(5)",
  "an1.219-234:1.6": "…   Mahāparisānaṁ yadidaṁ uruvelakassapo.\n(6)",
  "an1.219-234:1.7": "…   Kulappasādakānaṁ yadidaṁ kāḷudāyī.\n(7)",
  "an1.219-234:1.8": "…   Appābādhānaṁ yadidaṁ bākulo.\n(8)",
  "an1.219-234:1.9": "…   Pubbenivāsaṁ anussarantānaṁ yadidaṁ sobhito.\n(9)",
  "an1.219-234:1.10": "…   Vinayadharānaṁ yadidaṁ upāli.\n(10)",
  "an1.219-234:1.11": "…   Bhikkhunovādakānaṁ yadidaṁ nandako.\n(11)",
  "an1.219-234:1.12": "…   Indriyesu guttadvārānaṁ yadidaṁ nando.\n(12)",
  "an1.219-234:1.13": "…   Bhikkhuovādakānaṁ yadidaṁ mahākappino.\n(13)",
  "an1.219-234:1.14": "…   Tejodhātukusalānaṁ yadidaṁ sāgato.\n(14)",
  "an1.219-234:1.15": "…   Paṭibhāneyyakānaṁ yadidaṁ rādho.\n(15)\n…   Lūkhacīvaradharānaṁ yadidaṁ mogharājā\"ti.\n(16)\nVaggo catuttho.\nCatutthavagga"
}