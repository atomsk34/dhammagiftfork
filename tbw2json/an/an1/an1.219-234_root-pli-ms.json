{
  "an1.219:0.1": "Aṅguttara Nikāya 1 ",
  "an1.219:0.2": "17. Catutthavagga ",
  "an1.219-234:1.1": "\"Etadaggaṁ, bhikkhave, mama sāvakānaṁ bhikkhūnaṁ bahussutānaṁ yadidaṁ ānando.",
  "an1.219-234:1.2": "…   Satimantānaṁ yadidaṁ ānando.",
  "an1.219-234:1.3": "…   Gatimantānaṁ yadidaṁ ānando.",
  "an1.219-234:1.4": "…   Dhitimantānaṁ yadidaṁ ānando.",
  "an1.219-234:1.5": "…   Upaṭṭhākānaṁ yadidaṁ ānando.",
  "an1.219-234:1.6": "…   Mahāparisānaṁ yadidaṁ uruvelakassapo.",
  "an1.219-234:1.7": "…   Kulappasādakānaṁ yadidaṁ kāḷudāyī.",
  "an1.219-234:1.8": "…   Appābādhānaṁ yadidaṁ bākulo.",
  "an1.219-234:1.9": "…   Pubbenivāsaṁ anussarantānaṁ yadidaṁ sobhito.",
  "an1.219-234:1.10": "…   Vinayadharānaṁ yadidaṁ upāli.",
  "an1.219-234:1.11": "…   Bhikkhunovādakānaṁ yadidaṁ nandako.",
  "an1.219-234:1.12": "…   Indriyesu guttadvārānaṁ yadidaṁ nando.",
  "an1.219-234:1.13": "…   Bhikkhuovādakānaṁ yadidaṁ mahākappino.",
  "an1.219-234:1.14": "…   Tejodhātukusalānaṁ yadidaṁ sāgato.",
  "an1.219-234:1.15": "…   Paṭibhāneyyakānaṁ yadidaṁ rādho.\n…   Lūkhacīvaradharānaṁ yadidaṁ mogharājā\"ti.\nVaggo catuttho.\nCatutthavagga"
}