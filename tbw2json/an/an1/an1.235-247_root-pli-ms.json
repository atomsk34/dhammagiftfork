{
  "an1.235:0.1": "Aṅguttara Nikāya 1 ",
  "an1.235:0.2": "18. Pañcamavagga ",
  "an1.235-247:1.1": "\"Etadaggaṁ, bhikkhave, mama sāvikānaṁ bhikkhunīnaṁ rattaññūnaṁ yadidaṁ mahāpajāpatigotamī.",
  "an1.235-247:1.2": "…   Mahāpaññānaṁ yadidaṁ khemā.",
  "an1.235-247:1.3": "…   Iddhimantīnaṁ yadidaṁ uppalavaṇṇā.",
  "an1.235-247:1.4": "…   Vinayadharānaṁ yadidaṁ paṭācārā.",
  "an1.235-247:1.5": "…   Dhammakathikānaṁ yadidaṁ dhammadinnā.",
  "an1.235-247:1.6": "…   Jhāyīnaṁ yadidaṁ nandā.",
  "an1.235-247:1.7": "…   Āraddhavīriyānaṁ yadidaṁ soṇā.",
  "an1.235-247:1.8": "…   Dibbacakkhukānaṁ yadidaṁ bakulā.",
  "an1.235-247:1.9": "…   Khippābhiññānaṁ yadidaṁ bhaddā kuṇḍalakesā.",
  "an1.235-247:1.10": "…   Pubbenivāsaṁ anussarantīnaṁ yadidaṁ bhaddā kāpilānī.",
  "an1.235-247:1.11": "…   Mahābhiññāpattānaṁ yadidaṁ bhaddakaccānā.",
  "an1.235-247:1.12": "…   Lūkhacīvaradharānaṁ yadidaṁ kisāgotamī.",
  "an1.235-247:1.13": "…   Saddhādhimuttānaṁ yadidaṁ siṅgālakamātā\"ti.\nVaggo pañcamo.\nPañcamavagga"
}