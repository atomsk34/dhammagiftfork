{
  "an1.235:0.1": "Aṅguttara Nikāya 1 ",
  "an1.235:0.2": "18. Pañcamavagga ",
  "an1.235-247:1.1": "\"Etadaggaṁ, bhikkhave, mama sāvikānaṁ bhikkhunīnaṁ rattaññūnaṁ yadidaṁ mahāpajāpatigotamī.\n(1)",
  "an1.235-247:1.2": "…   Mahāpaññānaṁ yadidaṁ khemā.\n(2)",
  "an1.235-247:1.3": "…   Iddhimantīnaṁ yadidaṁ uppalavaṇṇā.\n(3)",
  "an1.235-247:1.4": "…   Vinayadharānaṁ yadidaṁ paṭācārā.\n(4)",
  "an1.235-247:1.5": "…   Dhammakathikānaṁ yadidaṁ dhammadinnā.\n(5)",
  "an1.235-247:1.6": "…   Jhāyīnaṁ yadidaṁ nandā.\n(6)",
  "an1.235-247:1.7": "…   Āraddhavīriyānaṁ yadidaṁ soṇā.\n(7)",
  "an1.235-247:1.8": "…   Dibbacakkhukānaṁ yadidaṁ bakulā.\n(8)",
  "an1.235-247:1.9": "…   Khippābhiññānaṁ yadidaṁ bhaddā kuṇḍalakesā.\n(9)",
  "an1.235-247:1.10": "…   Pubbenivāsaṁ anussarantīnaṁ yadidaṁ bhaddā kāpilānī.\n(10)",
  "an1.235-247:1.11": "…   Mahābhiññāpattānaṁ yadidaṁ bhaddakaccānā.\n(11)",
  "an1.235-247:1.12": "…   Lūkhacīvaradharānaṁ yadidaṁ kisāgotamī.\n(12)",
  "an1.235-247:1.13": "…   Saddhādhimuttānaṁ yadidaṁ siṅgālakamātā\"ti.\n(13)\nVaggo pañcamo.\nPañcamavagga"
}