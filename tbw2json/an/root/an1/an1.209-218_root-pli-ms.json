{
  "an1.209-218:1.0.1": "\"Etadaggaṁ, bhikkhave, mama sāvakānaṁ bhikkhūnaṁ sikkhākāmānaṁ yadidaṁ rāhulo.(1)",
  "an1.209-218:1.0.2": "…   Saddhāpabbajitānaṁ yadidaṁ raṭṭhapālo.(2)",
  "an1.209-218:1.0.3": "…   Paṭhamaṁ salākaṁ gaṇhantānaṁ yadidaṁ kuṇḍadhāno.(3)",
  "an1.209-218:1.0.4": "…   Paṭibhānavantānaṁ yadidaṁ vaṅgīso.(4)",
  "an1.209-218:1.0.5": "…   Samantapāsādikānaṁ yadidaṁ upaseno vaṅgantaputto.(5)",
  "an1.209-218:1.0.6": "…   Senāsanapaññāpakānaṁ yadidaṁ dabbo mallaputto.(6)",
  "an1.209-218:1.0.7": "…   Devatānaṁ piyamanāpānaṁ yadidaṁ pilindavaccho.(7)",
  "an1.209-218:1.0.8": "…   Khippābhiññānaṁ yadidaṁ bāhiyo dārucīriyo.(8)",
  "an1.209-218:1.0.9": "…   Cittakathikānaṁ yadidaṁ kumārakassapo.(9)",
  "an1.209-218:1.0.10": "…   Paṭisambhidāpattānaṁ yadidaṁ mahākoṭṭhito\"ti.(10)"
}