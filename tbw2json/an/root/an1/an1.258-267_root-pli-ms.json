{
  "an1.258-267:1.0.1": "\"Etadaggaṁ, bhikkhave, mama sāvikānaṁ upāsikānaṁ paṭhamaṁ saraṇaṁ gacchantīnaṁ yadidaṁ sujātā seniyadhītā.(1)",
  "an1.258-267:1.0.2": "…   Dāyikānaṁ yadidaṁ visākhā migāramātā.(2)",
  "an1.258-267:1.0.3": "…   Bahussutānaṁ yadidaṁ khujjuttarā.(3)",
  "an1.258-267:1.0.4": "…   Mettāvihārīnaṁ yadidaṁ sāmāvatī.(4)",
  "an1.258-267:1.0.5": "…   Jhāyīnaṁ yadidaṁ uttarānandamātā.(5)",
  "an1.258-267:1.0.6": "…   Paṇītadāyikānaṁ yadidaṁ suppavāsā koliyadhītā.(6)",
  "an1.258-267:1.0.7": "…   Gilānupaṭṭhākīnaṁ yadidaṁ suppiyā upāsikā.(7)",
  "an1.258-267:1.0.8": "…   Aveccappasannānaṁ yadidaṁ kātiyānī.(8)",
  "an1.258-267:1.0.9": "…   Vissāsikānaṁ yadidaṁ nakulamātā gahapatānī.(9)",
  "an1.258-267:1.0.10": "…   Anussavappasannānaṁ yadidaṁ kāḷī upāsikā kuraragharikā\"ti.(10)"
}