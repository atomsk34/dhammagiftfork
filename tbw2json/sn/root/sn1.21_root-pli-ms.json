{
  "sn1.21:1.0.1": "Sāvatthinidānaṁ. Ekamantaṁ ṭhitā kho sā devatā bhagavato santike imaṁ gāthaṁ abhāsi:",
  "sn1.21:1.0.2": "\"Sattiyā viya omaṭṭho,ḍayhamānova matthake;Kāmarāgappahānāya,sato bhikkhu paribbaje\"ti.",
  "sn1.21:1.0.3": "\"Sattiyā viya omaṭṭho,ḍayhamānova matthake;Sakkāyadiṭṭhippahānāya,sato bhikkhu paribbaje\"ti."
}