{
  "sn1.21:1.1": "Sāvatthinidānaṁ. Ekamantaṁ ṭhitā kho sā devatā bhagavato santike imaṁ gāthaṁ abhāsi:",
  "sn1.21:2.1": "\"Sattiyā viya omaṭṭho,ḍayhamānova matthake;Kāmarāgappahānāya,sato bhikkhu paribbaje\"ti.",
  "sn1.21:2.2": "",
  "sn1.21:3.1": "\"Sattiyā viya omaṭṭho,ḍayhamānova matthake;Sakkāyadiṭṭhippahānāya,sato bhikkhu paribbaje\"ti."
}